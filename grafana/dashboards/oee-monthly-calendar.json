        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Aylik takvim gorunumu: secili tarih araligindaki her gun icin tezgah basina RUNNING / IDLE / STOPPED / OFFLINE saatleri. Time-picker'dan ayi sec (Quick range -> This month veya custom).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": ["oee"],
      "targetBlank": false,
      "title": "Diger OEE panolari",
      "tooltip": "OEE klasoru",
      "type": "dashboards",
      "url": ""
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Aylik takvim - tezgah basina gunluk saat dagilimi",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "influxdb-mtconnect" },
      "description": "Secili tarih araliginda her gun icin bu tezgahin RUNNING / IDLE / STOPPED / OFFLINE durumunda gecirdigi saat sayisi. Stacked bar; toplam = 24 saat (eger gun tam ise).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "saat",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1,
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
          },
          "decimals": 1,
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "unit": "h",
          "max": 24,
          "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "RUNNING" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green"  } } ] },
          { "matcher": { "id": "byName", "options": "IDLE" },    "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue"   } } ] },
          { "matcher": { "id": "byName", "options": "STOPPED" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "OFFLINE" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red"    } } ] }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "maxPerRow": 2,
      "options": {
        "barRadius": 0,
        "barWidth": 0.9,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "vertical",
        "showValue": "never",
        "stacking": "normal",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "xField": "_time",
        "xTickLabelRotation": -45,
        "xTickLabelSpacing": 0
      },
      "pluginVersion": "11.3.0",
      "repeat": "cal_machine",
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-mtconnect" },
          "query": "import \"date\"\n\npoll = 2.0\n\nreachable_off = from(bucket: \"mtconnect\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r.machine_id == \"${cal_machine}\" and r._measurement == \"mtconnect_status\" and r._field == \"reachable\" and r._value == false)\n  |> map(fn: (r) => ({ _time: r._time, _value: 1, state: \"OFFLINE\" }))\n\nexecs = from(bucket: \"mtconnect\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r.machine_id == \"${cal_machine}\" and r._measurement == \"mtconnect\" and r.item_type == \"Execution\" and r._field == \"value_str\")\n  |> map(fn: (r) => ({\n      _time: r._time,\n      _value: 1,\n      state: if r._value == \"ACTIVE\" then \"RUNNING\"\n             else if r._value == \"UNAVAILABLE\" then \"STOPPED\"\n             else \"IDLE\"\n  }))\n\nunion(tables: [reachable_off, execs])\n  |> group(columns: [\"state\"])\n  |> aggregateWindow(every: 1d, fn: sum, createEmpty: true)\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) * poll / 3600.0 }))\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"state\"], valueColumn: \"_value\")",
          "refId": "A"
        }
      ],
      "title": "$cal_machine - gunluk saat dagilimi",
      "type": "barchart"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["oee", "mtconnect", "se-havacilik", "calendar"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "influxdb", "uid": "influxdb-mtconnect" },
        "definition": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"mtconnect\", tag: \"machine_id\")",
        "description": "Repeat tetikleyici. Her secili tezgah icin bir bar chart panel render edilir.",
        "includeAll": true,
        "label": "Tezgah",
        "multi": true,
        "name": "cal_machine",
        "options": [],
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"mtconnect\", tag: \"machine_id\")",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now/M", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5m", "15m", "30m", "1h"],
    "time_options": ["7d", "30d", "60d", "90d"]
  },
  "timezone": "browser",
  "title": "SE Havacilik - Aylik Takvim",
  "uid": "oee-monthly-calendar",
  "version": 1,
  "weekStart": ""
}
