# InfluxDB initial setup (only used on first start of the influxdb volume)
INFLUX_USERNAME=admin
INFLUX_PASSWORD=ChangeMe-Strong-Password!
INFLUX_ORG=se-havacilik
INFLUX_BUCKET=mtconnect
# Generate a long random token, e.g. on Linux: openssl rand -hex 32
# On Windows PowerShell: -join ((48..57)+(97..102) | Get-Random -Count 64 | % {[char]$_})
INFLUX_TOKEN=replace-with-a-long-random-token
# Bucket retention in seconds (0 = infinite)
INFLUX_RETENTION=0
# Host port to expose InfluxDB UI/API on (UI: http://localhost:8086)
INFLUX_PORT=8086

# Collector tuning
POLL_INTERVAL=2
HTTP_TIMEOUT=5
LOG_LEVEL=INFO
